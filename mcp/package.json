{
  "name": "hanji-mcp",
  "version": "0.1.0-alpha.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "MCP server exposing the Hanji workspace (pages, blocks, search) to AI agents.",
  "bin": {
    "hanji-mcp": "src/index.mjs"
  },
  "scripts": {
    "start": "node src/index.mjs",
    "check": "node --check src/index.mjs && node --check src/edgebase.mjs && node --check src/legacy-product-compat.mjs && node --check scripts/smoke.mjs && node --check scripts/tool-invocation-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "node --test tests/*.test.mjs",
    "smoke": "node scripts/smoke.mjs && node scripts/tool-invocation-smoke.mjs",
    "smoke:live": "node scripts/live-smoke.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "typescript": "~5.9.0"
  }
}
