# Notionlike production environment
#
# Copy to .env.release, replace every required value, and run:
#   npm run preflight:deploy
# EdgeBase deploy synchronizes supported values to Cloudflare secrets. Never
# commit .env.release. SERVICE_KEY is managed by the EdgeBase deploy pipeline.

# Required cryptographic secrets (generate independent random values, 32+ chars)
JWT_USER_SECRET=
JWT_ADMIN_SECRET=
NOTIONLIKE_NOTION_IMPORT_SECRET=
NOTIONLIKE_MCP_OAUTH_SECRET=

# Required canonical production origin and WebAuthn relying-party scope
NOTIONLIKE_APP_ORIGIN=https://app.example.com
NOTIONLIKE_PASSKEY_RP_ID=example.com
NOTIONLIKE_PASSKEY_ORIGINS=https://app.example.com

# Required mail identity. For hosted Workers, configure the send_email binding;
# for Docker/portable runtimes, set both REST API credentials instead.
NOTIONLIKE_AUTH_EMAIL_FROM=no-reply@example.com
NOTIONLIKE_CLOUDFLARE_EMAIL_BINDING=EMAIL
# NOTIONLIKE_CLOUDFLARE_EMAIL_ACCOUNT_ID=
# NOTIONLIKE_CLOUDFLARE_EMAIL_API_TOKEN=

# Required first instance-administrator bootstrap allowlist. Set at least one.
# Ordinary workspace owners never receive instance-admin rights implicitly.
NOTIONLIKE_INSTANCE_ADMIN_EMAILS=admin@example.com
# NOTIONLIKE_INSTANCE_ADMIN_USER_IDS=

# Recommended deployment identity surfaced by the health endpoint.
NOTIONLIKE_BUILD_SHA=

# Optional product OAuth providers. Every listed provider needs both values.
# NOTIONLIKE_AUTH_OAUTH_PROVIDERS=google,github
# NOTIONLIKE_OAUTH_GOOGLE_CLIENT_ID=
# NOTIONLIKE_OAUTH_GOOGLE_CLIENT_SECRET=
# NOTIONLIKE_OAUTH_GITHUB_CLIENT_ID=
# NOTIONLIKE_OAUTH_GITHUB_CLIENT_SECRET=

# Optional Notion OAuth connection flow. Set all four together. Without these,
# users can still import with a user-supplied Notion integration token.
# NOTIONLIKE_NOTION_OAUTH_CLIENT_ID=
# NOTIONLIKE_NOTION_OAUTH_CLIENT_SECRET=
# NOTIONLIKE_NOTION_OAUTH_REDIRECT_URI=https://app.example.com/api/functions/notion-import/oauth/callback
# NOTIONLIKE_NOTION_OAUTH_STATE_SECRET=

# Optional hosted MCP policy overrides
# NOTIONLIKE_MCP_PUBLIC_ORIGIN=https://app.example.com
# NOTIONLIKE_MCP_RESOURCE=https://app.example.com/api/functions/mcp
# NOTIONLIKE_MCP_SCOPES=pages:read,pages:write,databases:read,databases:write,comments:read,comments:write,workspace:read

# Optional import/runtime tuning
# NOTIONLIKE_NOTION_IMPORT_JOB_RETENTION_DAYS=30
# NOTIONLIKE_SSRF_DNS_CHECK=on
# NOTIONLIKE_SSRF_DOH_URL=https://cloudflare-dns.com/dns-query

# Database provider connection (only for provider: neon/postgres)
# DB_POSTGRES_SHARED_URL=postgres://user:pass@host/db?sslmode=require
