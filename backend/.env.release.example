# Hanji production environment
#
# Copy to .env.release, replace every required value, and run:
#   npm run preflight:deploy
# EdgeBase deploy synchronizes supported values to Cloudflare secrets. Never
# commit .env.release; chmod it 0600 (0400 is also accepted). SERVICE_KEY is
# managed by the EdgeBase deploy pipeline. Every assignment marked required
# must remain present in this file even when the invoking shell overrides it.
# Strict release validation rejects active pre-Hanji environment variable
# names from both this file and the invoking shell; use HANJI_* names only.

# Required cryptographic secrets (generate independent random values, 32+ chars)
JWT_USER_SECRET=
JWT_ADMIN_SECRET=
HANJI_NOTION_IMPORT_SECRET=
HANJI_MCP_OAUTH_SECRET=
# Optional key-rotation fallback. Keep the declarations empty to clear stale
# hosted secrets, or set each secret/timestamp pair together; timestamps are
# canonical UTC ISO-8601 and valid for at most 28 days.
JWT_USER_SECRET_OLD=
JWT_USER_SECRET_OLD_AT=
JWT_ADMIN_SECRET_OLD=
JWT_ADMIN_SECRET_OLD_AT=

# Required exact canonical public HTTPS origin. Documentation domains below are
# intentional placeholders and are rejected until replaced with a real domain.
HANJI_APP_ORIGIN=https://app.example.com
# Required safe release toggles overwrite stale development Worker secrets.
HANJI_ALLOW_DEV_GUEST_LOGIN=false
HANJI_MASTER_DEV_AUTOLOGIN=false
HANJI_RATE_LIMIT_PROFILE=production
# Passkeys are currently disabled in edgebase.config.ts. When deliberately
# re-enabling them, configure both values together and validate the real origin.
# Empty declarations neutralize stale hosted aliases while passkeys stay off.
HANJI_PASSKEY_RP_ID=
HANJI_PASSKEY_ORIGINS=

# Required mail identity. Hosted deploys prove the exact EMAIL send_email
# binding from backend/wrangler.toml. Docker/portable runtimes need both REST
# credentials (32-hex account ID and strong 40+ character API token).
HANJI_AUTH_EMAIL_FROM=no-reply@example.com
HANJI_CLOUDFLARE_EMAIL_BINDING=EMAIL
# Keep both empty for the hosted EMAIL binding so deploy neutralizes stale REST
# credentials. Portable runtimes may instead set both to valid values.
HANJI_CLOUDFLARE_EMAIL_ACCOUNT_ID=
HANJI_CLOUDFLARE_EMAIL_API_TOKEN=

# Required master account. The server provisions this account on first boot,
# promotes it to instance admin, and refuses to initialize a fresh instance
# without it. The password is only used at creation time; changing it later
# happens in Account Security or via `npx edgebase admin reset-password`. Use
# 16-256 diverse characters including upper/lowercase, number, and special.
HANJI_MASTER_EMAIL=master@example.com
HANJI_MASTER_PASSWORD=

# Optional additional instance-administrator bootstrap by immutable auth user ID.
# Exact lowercase `off` clears stale hosted authority; otherwise list IDs.
# Email allowlists are retired because password-signup emails are unverified.
HANJI_INSTANCE_ADMIN_USER_IDS=off

# Required full 40/64-character Git object ID. Strict release requires it to
# match a clean public checkout's HEAD and the source URL path below.
HANJI_BUILD_SHA=

# Required public legal/source links shown to every user. Point these at the
# exact public revision and matching license texts. The strict deploy preflight
# resolves and fetches all three; placeholders, private targets, and 4xx/5xx
# responses fail the release gate.
HANJI_SOURCE_URL=
HANJI_AGPL_LICENSE_URL=
HANJI_SPONSOR_EXCEPTION_URL=

# Optional product OAuth providers. Every listed supported provider needs a
# non-placeholder client ID and an independent strong client secret. The UI
# reads the completed provider list from runtime-config; no Vite mirror exists.
# Exact lowercase `off` clears stale hosted provider enablement; otherwise set
# a supported list such as google,github.
HANJI_AUTH_OAUTH_PROVIDERS=off
# HANJI_OAUTH_GOOGLE_CLIENT_ID=
# HANJI_OAUTH_GOOGLE_CLIENT_SECRET=
# HANJI_OAUTH_GITHUB_CLIENT_ID=
# HANJI_OAUTH_GITHUB_CLIENT_SECRET=

# Optional Notion OAuth connection flow. Set all four together. Without these,
# users can still import with a user-supplied Notion integration token.
# These two upstream endpoints are required exact safe values even when OAuth
# is disabled, so deploy overwrites any stale Worker secret from older builds.
HANJI_NOTION_API_BASE=https://api.notion.com/v1
HANJI_NOTION_OAUTH_AUTH_URL=https://api.notion.com/v1/oauth/authorize
# Keep all four declarations empty to disable/clear stale hosted OAuth, or set
# all four together. Redirect example: https://app.example.com/?notion_import_oauth=1
HANJI_NOTION_OAUTH_ENABLED=false
HANJI_NOTION_OAUTH_CLIENT_ID=
HANJI_NOTION_OAUTH_CLIENT_SECRET=
HANJI_NOTION_OAUTH_REDIRECT_URI=
HANJI_NOTION_OAUTH_STATE_SECRET=

# MCP resource/scope options belong to the separate stdio process and do not
# live in backend env. The hosted origin always comes from HANJI_APP_ORIGIN.
# Required safe value: trusting arbitrary forwarded IP headers would bypass the
# anonymous dynamic-client-registration rate-limit identity boundary.
HANJI_MCP_TRUST_PROXY_HEADERS=false

# Required bounded import-job metadata retention. This overwrites stale remote
# values; completed jobs remain additionally bounded by the per-workspace cap.
HANJI_NOTION_IMPORT_JOB_RETENTION_DAYS=14
# Required safe value: caller-supplied URL DNS verification remains enabled.
HANJI_SSRF_DNS_CHECK=on
# Required exact resolver and fail-closed debug setting overwrite stale hosted
# Worker secrets left by older deployments.
HANJI_SSRF_DOH_URL=https://cloudflare-dns.com/dns-query
HANJI_DEBUG_ROOM_ACCESS=0

# Database provider connection (only for provider: neon/postgres)
# DB_POSTGRES_SHARED_URL=postgres://user:pass@host/db?sslmode=require

# Strict releases must explicitly select one mode so deploy overwrites a stale
# Worker secret. The exact URL below is the recommended live feed; `bundled`
# uses the unmodified shipped offline snapshot with no request. The feed cannot
# be replaced; `off` intentionally disables the feature (the Sponsor Banner
# Exception then does not apply to that deployment).
HANJI_SPONSORS_FEED_URL=https://hanji-sponsors-service.melodydreamj.workers.dev/sponsors
