# EdgeBase Development Environment Variables — EXAMPLE
# Prefer: run `node scripts/setup-dev-env.mjs` from the repo root, which
# creates .env.development and .dev.vars with fresh random values.
# Manual alternative: copy this file to both names and fill the values.

# Dev-only random secrets (32+ chars each)
JWT_USER_SECRET=
JWT_ADMIN_SECRET=

# Service key for trusted admin/MCP access (local dev)
SERVICE_KEY=

# Per-workspace Durable Object split (required by the current data model)
HANJI_WORKSPACE_DO_SPLIT=true
