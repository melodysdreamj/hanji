{
  "name": "hanji-web",
  "version": "0.1.0-alpha.4",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && node scripts/generate-sw-precache.mjs && node ../scripts/verify-hanji-namespace.mjs --generated",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "i18n:status": "node ../scripts/i18n-status.mjs",
    "i18n:sync": "node ../scripts/i18n-status.mjs --sync"
  },
  "dependencies": {
    "@edge-base/web": "0.4.9",
    "@phosphor-icons/react": "^2.1.10",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.10",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^26",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^7",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.5",
    "vitest": "^4.1.9"
  }
}
